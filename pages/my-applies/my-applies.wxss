.container {
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 用户信息 */
.user-info {
  background-color: var(--card-background);
  padding: 36rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 30rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 8rpx;
  display: block;
}

.user-studentId,
.user-college {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 5rpx;
  display: block;
}

/* 标签切换 */
.tab-bar {
  background-color: var(--card-background);
  display: flex;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  border-radius: 16rpx 16rpx 0 0;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: var(--primary-color);
  border-radius: 2rpx;
}

/* 报名列表 */
.applies-list {
  padding: 0 20rpx 20rpx;
}

.apply-item {
  background-color: var(--card-background);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.apply-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.activity-cover {
  width: 100%;
  height: 200rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx 16rpx 0 0;
}

.activity-cover image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx 16rpx 0 0;
  object-fit: cover;
}

.apply-info {
  padding: 24rpx;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.3;
}

.activity-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.activity-time {
  margin-right: 30rpx;
  display: flex;
  align-items: center;
}

.activity-time::before {
  content: '⏰';
  margin-right: 8rpx;
  font-size: 20rpx;
}

.activity-location {
  display: flex;
  align-items: center;
}

.activity-location::before {
  content: '📍';
  margin-right: 8rpx;
  font-size: 20rpx;
}

.apply-status {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-badge.pending {
  background-color: rgba(255, 149, 0, 0.1);
  color: var(--warning-color);
}

.status-badge.approved {
  background-color: rgba(52, 199, 89, 0.1);
  color: var(--secondary-color);
}

.status-badge.rejected {
  background-color: rgba(255, 59, 48, 0.1);
  color: var(--error-color);
}

.apply-time {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.no-applies {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .user-info {
    padding: 28rpx;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .user-name {
    font-size: 28rpx;
  }
  
  .apply-info {
    padding: 20rpx;
  }
  
  .activity-title {
    font-size: 26rpx;
  }
  
  .activity-meta {
    font-size: 22rpx;
  }
}
