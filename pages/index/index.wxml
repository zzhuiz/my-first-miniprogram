<!--index.wxml-->
<view class="container">
  <!-- 分类筛选 -->
  <view class="category-filter">
    <scroll-view scroll-x="true" class="category-scroll">
      <view 
        wx:for="{{categories}}" 
        wx:key="{{item}}"
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </scroll-view>
  </view>
  
  <!-- 活动列表 -->
  <view class="activity-list">
    <view 
      wx:for="{{activities}}" 
      wx:key="{{item._id}}"
      class="activity-item"
      bindtap="onActivityTap"
      data-id="{{item._id}}"
    >
      <view class="activity-cover">
        <image src="{{item.cover || '../../images/home.png'}}" mode="aspectFill"></image>
      </view>
      <view class="activity-info">
        <text class="activity-title">{{item.title}}</text>
        <view class="activity-meta">
          <text class="activity-time">{{item.time}}</text>
          <text class="activity-location">{{item.location}}</text>
        </view>
        <view class="activity-status">
          <text class="participants">{{item.applyCount}}/{{item.maxParticipants}}人</text>
          <text class="status {{item.applyCount >= item.maxParticipants ? 'full' : ''}}">
            {{item.applyCount >= item.maxParticipants ? '已截止' : '可报名'}}
          </text>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text bindtap="loadMore">加载更多</text>
    </view>
    
    <!-- 无活动 -->
    <view class="no-activity" wx:if="{{activities.length === 0}}">
      <text>暂无活动</text>
    </view>
  </view>
  
  <!-- 发布活动按钮 -->
  <button 
    class="publish-button" 
    bindtap="onPublish"
  >
    + 发布活动
  </button>
</view>
