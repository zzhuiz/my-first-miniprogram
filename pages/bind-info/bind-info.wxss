.container {
  padding: 30rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

.header {
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.4;
}

.form {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background-color: var(--card-background);
  transition: border-color 0.2s ease;
}

.input:focus {
  border-color: var(--primary-color);
  outline: none;
}

.submit-button {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary-color);
  color: white;
  font-size: 18px;
  font-weight: 600;
  border-radius: 12rpx;
  margin-top: 40rpx;
  box-shadow: 0 4px 12px rgba(0, 122, 255, 0.3);
  transition: all 0.2s ease;
}

.submit-button:hover {
  background-color: #0066CC;
  box-shadow: 0 6px 16px rgba(0, 122, 255, 0.4);
}

.submit-button:disabled {
  background-color: #E5E5EA;
  color: #8E8E93;
  box-shadow: none;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .header {
    margin-bottom: 40rpx;
  }
  
  .title {
    font-size: 32rpx;
  }
  
  .form {
    padding: 28rpx;
  }
  
  .input {
    height: 80rpx;
  }
  
  .submit-button {
    height: 80rpx;
    font-size: 16px;
  }
}